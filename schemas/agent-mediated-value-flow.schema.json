{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://github.com/SamuraiWriter7/royalty-os-v0.5/schemas/agent-mediated-value-flow.schema.json",
"title": "Agent-Mediated Value Flow Record",
"description": "Schema for validating an end-to-end agent-mediated value flow in Royalty OS v0.5. This flow connects a personal AI agent, personal trace fingerprint, usage detection event, attribution route, claim route, return route, and representative event log into a single reviewable workflow. It must not be treated as automatic proof of ownership, infringement, compensation, payment obligation, or claim validity.",
"type": "object",
"additionalProperties": false,
"required": [
"flow_id",
"schema_version",
"flow_type",
"status",
"title",
"description",
"core_principle",
"participants",
"flow_records",
"flow_steps",
"value_flow_summary",
"review_model",
"boundary_policy",
"privacy_policy",
"governance",
"audit",
"external_references",
"created_at"
],
"properties": {
"flow_id": {
"type": "string",
"description": "Unique identifier for the agent-mediated value flow.",
"pattern": "^[a-zA-Z0-9.*:-]+$",
"minLength": 3,
"maxLength": 200
},
"schema_version": {
"type": "string",
"description": "Schema version used by this record.",
"const": "v0.5.0-draft"
},
"flow_type": {
"type": "string",
"description": "Type of flow represented by this record.",
"const": "agent_mediated_value_flow"
},
"status": {
"type": "string",
"description": "Current lifecycle status of the flow.",
"enum": [
"draft",
"candidate",
"submitted_for_review",
"under_review",
"accepted_for_review",
"rejected",
"disputed",
"archived",
"resolved"
]
},
"title": {
"type": "string",
"description": "Human-readable title of the flow.",
"minLength": 1,
"maxLength": 240
},
"description": {
"type": "string",
"description": "Human-readable description of the flow.",
"minLength": 1,
"maxLength": 4000
},
"core_principle": {
"type": "string",
"description": "Core principle governing the flow.",
"minLength": 1,
"maxLength": 2000
},
"participants": {
"type": "object",
"description": "Participants involved in the agent-mediated value flow.",
"additionalProperties": false,
"required": [
"represented_individual",
"personal_ai_agent"
],
"properties": {
"represented_individual": {
"type": "object",
"additionalProperties": false,
"required": [
"individual_id",
"individual_type"
],
"properties": {
"individual_id": {
"type": "string",
"pattern": "^[a-zA-Z0-9.*:-]+$",
"minLength": 3,
"maxLength": 180
},
"individual_type": {
"type": "string",
"enum": [
"individual",
"creator",
"researcher",
"developer",
"organization",
"collective",
"agent_represented_individual",
"other"
]
},
"display_name": {
"type": "string",
"maxLength": 200
}
}
},
"personal_ai_agent": {
"type": "object",
"additionalProperties": false,
"required": [
"agent_id",
"agent_name",
"agent_record_reference",
"role_in_flow"
],
"properties": {
"agent_id": {
"type": "string",
"pattern": "^[a-zA-Z0-9.*:-]+$",
"minLength": 3,
"maxLength": 180
},
"agent_name": {
"type": "string",
"minLength": 1,
"maxLength": 200
},
"agent_record_reference": {
"type": "string",
"maxLength": 300
},
"role_in_flow": {
"type": "string",
"enum": [
"personal_representative_agent",
"trace_manager",
"usage_detection_assistant",
"attribution_route_assistant",
"claim_route_assistant",
"return_route_assistant",
"representative_event_logger",
"other"
]
}
}
}
}
},
"flow_records": {
"type": "object",
"description": "Record references that make up the full v0.5 flow.",
"additionalProperties": false,
"required": [
"personal_agent",
"trace_fingerprint",
"usage_detection_event",
"attribution_route",
"claim_route",
"return_route",
"representative_event"
],
"properties": {
"personal_agent": {
"$ref": "#/$defs/flowRecord"
},
"trace_fingerprint": {
"$ref": "#/$defs/flowRecord"
},
"usage_detection_event": {
"$ref": "#/$defs/flowRecord"
},
"attribution_route": {
"$ref": "#/$defs/flowRecord"
},
"claim_route": {
"$ref": "#/$defs/flowRecord"
},
"return_route": {
"$ref": "#/$defs/flowRecord"
},
"representative_event": {
"$ref": "#/$defs/flowRecord"
}
}
},
"flow_steps": {
"type": "array",
"description": "Ordered steps in the agent-mediated value flow.",
"minItems": 1,
"items": {
"$ref": "#/$defs/flowStep"
}
},
"value_flow_summary": {
"type": "object",
"description": "Summary of the sequence and meaning of the value flow.",
"additionalProperties": false,
"required": [
"sequence",
"meaning"
],
"properties": {
"sequence": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"maxLength": 200
}
},
"meaning": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"maxLength": 300
}
}
}
},
"review_model": {
"type": "object",
"description": "Review requirements for the integrated flow.",
"additionalProperties": false,
"required": [
"human_review_required",
"review_required_for",
"default_review_status"
],
"properties": {
"human_review_required": {
"type": "boolean",
"const": true
},
"review_required_for": {
"type": "array",
"minItems": 1,
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"usage_interpretation",
"attribution_interpretation",
"claim_interpretation",
"return_interpretation",
"ownership_interpretation",
"compensation_assessment",
"payment_execution",
"wallet_reference",
"public_disclosure",
"external_sharing",
"external_process",
"governance_action",
"escalation"
]
}
},
"default_review_status": {
"type": "string",
"enum": [
"unreviewed",
"under_review",
"accepted_for_review",
"rejected",
"disputed",
"escalated",
"archived",
"resolved"
]
}
}
},
"boundary_policy": {
"type": "object",
"description": "Boundary rules for interpreting the integrated flow.",
"additionalProperties": false,
"required": [
"detection_is_not_proof",
"attribution_is_not_payment",
"claim_route_is_not_enforcement",
"return_route_is_not_execution",
"representative_event_is_not_execution",
"similarity_is_not_proof",
"no_automatic_ownership",
"no_automatic_compensation",
"no_automatic_payment",
"no_automatic_enforcement",
"no_automatic_accusation",
"requires_human_review"
],
"properties": {
"detection_is_not_proof": {
"type": "boolean",
"const": true
},
"attribution_is_not_payment": {
"type": "boolean",
"const": true
},
"claim_route_is_not_enforcement": {
"type": "boolean",
"const": true
},
"return_route_is_not_execution": {
"type": "boolean",
"const": true
},
"representative_event_is_not_execution": {
"type": "boolean",
"const": true
},
"similarity_is_not_proof": {
"type": "boolean",
"const": true
},
"no_automatic_ownership": {
"type": "boolean",
"const": true
},
"no_automatic_compensation": {
"type": "boolean",
"const": true
},
"no_automatic_payment": {
"type": "boolean",
"const": true
},
"no_automatic_enforcement": {
"type": "boolean",
"const": true
},
"no_automatic_accusation": {
"type": "boolean",
"const": true
},
"requires_human_review": {
"type": "boolean",
"const": true
}
}
},
"privacy_policy": {
"type": "object",
"description": "Privacy constraints for the integrated flow.",
"additionalProperties": false,
"required": [
"minimal_disclosure",
"private_trace_data_included",
"private_evidence_included",
"sensitive_wallet_credentials_included",
"public_summary_allowed",
"external_sharing_requires_review"
],
"properties": {
"minimal_disclosure": {
"type": "boolean",
"default": true
},
"private_trace_data_included": {
"type": "boolean",
"default": false
},
"private_evidence_included": {
"type": "boolean",
"default": false
},
"sensitive_wallet_credentials_included": {
"type": "boolean",
"const": false
},
"public_summary_allowed": {
"type": "boolean",
"default": true
},
"external_sharing_requires_review": {
"type": "boolean",
"default": true
}
}
},
"governance": {
"type": "object",
"description": "Governance state for the integrated flow.",
"additionalProperties": false,
"required": [
"governance_status",
"governance_actions"
],
"properties": {
"governance_status": {
"type": "string",
"enum": [
"none",
"review_requested",
"under_review",
"accepted_for_review",
"rejected",
"disputed",
"escalated",
"prepared_for_external_process",
"resolved",
"archived"
]
},
"governance_actions": {
"type": "array",
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"review_request",
"dispute_request",
"correction_request",
"attribution_review",
"claim_review",
"return_route_review",
"compensation_review",
"external_process_review",
"governance_escalation",
"archive"
]
}
},
"governance_notes": {
"type": "string",
"maxLength": 3000
}
}
},
"audit": {
"type": "object",
"description": "Audit metadata for the integrated flow.",
"additionalProperties": false,
"required": [
"audit_required",
"audit_status",
"representative_event_reference",
"audit_summary"
],
"properties": {
"audit_required": {
"type": "boolean",
"default": true
},
"audit_status": {
"type": "string",
"enum": [
"not_required",
"pending",
"under_review",
"accepted",
"rejected",
"archived"
]
},
"representative_event_reference": {
"type": "string",
"pattern": "^[a-zA-Z0-9.*:-]+$",
"minLength": 3,
"maxLength": 220
},
"audit_summary": {
"type": "string",
"minLength": 1,
"maxLength": 3000
}
}
},
"external_references": {
"type": "object",
"description": "References to related specs, documents, schemas, and examples.",
"additionalProperties": false,
"required": [
"royalty_os_version",
"related_specs",
"related_docs",
"related_schemas",
"related_examples"
],
"properties": {
"royalty_os_version": {
"type": "string",
"const": "v0.5.0-draft"
},
"related_specs": {
"type": "array",
"items": {
"type": "string",
"maxLength": 300
}
},
"related_docs": {
"type": "array",
"items": {
"type": "string",
"maxLength": 300
}
},
"related_schemas": {
"type": "array",
"items": {
"type": "string",
"maxLength": 300
}
},
"related_examples": {
"type": "array",
"items": {
"type": "string",
"maxLength": 300
}
}
}
},
"notes": {
"type": "string",
"description": "Optional notes about this integrated flow.",
"maxLength": 4000
},
"created_at": {
"type": "string",
"description": "Creation timestamp in date-time format.",
"format": "date-time"
},
"updated_at": {
"type": "string",
"description": "Last update timestamp in date-time format.",
"format": "date-time"
}
},
"$defs": {
"flowRecord": {
"type": "object",
"additionalProperties": false,
"required": [
"record_id",
"record_type",
"record_reference",
"purpose"
],
"properties": {
"record_id": {
"type": "string",
"pattern": "^[a-zA-Z0-9._:-]+$",
"minLength": 3,
"maxLength": 220
},
"record_type": {
"type": "string",
"enum": [
"personal_agent",
"personal_trace_fingerprint",
"agent_mediated_usage_detection_event",
"attribution_route",
"claim_route",
"return_route",
"representative_event",
"other"
]
},
"record_reference": {
"type": "string",
"maxLength": 300
},
"purpose": {
"type": "string",
"minLength": 1,
"maxLength": 3000
}
}
},
"flowStep": {
"type": "object",
"additionalProperties": false,
"required": [
"step",
"name",
"record_reference",
"input",
"output",
"summary",
"boundary"
],
"properties": {
"step": {
"type": "integer",
"minimum": 1
},
"name": {
"type": "string",
"minLength": 1,
"maxLength": 220
},
"record_reference": {
"type": "string",
"maxLength": 300
},
"input": {
"type": "string",
"maxLength": 500
},
"output": {
"type": "string",
"maxLength": 500
},
"summary": {
"type": "string",
"minLength": 1,
"maxLength": 3000
},
"boundary": {
"type": "string",
"minLength": 1,
"maxLength": 3000
}
}
}
}
}
