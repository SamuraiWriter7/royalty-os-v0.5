{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://github.com/SamuraiWriter7/royalty-os-v0.5/schemas/attribution-route.schema.json",
"title": "Attribution Route Record",
"description": "Schema for validating an attribution route record in Royalty OS v0.5. An attribution route connects a detected usage relationship back to a person, trace, work, prompt, structure, document, or agent. It is a reviewable traceability structure and must not be treated as automatic proof of ownership, infringement, compensation, or claim validity.",
"type": "object",
"additionalProperties": false,
"required": [
"attribution_route_id",
"schema_version",
"route_type",
"status",
"source_trace_reference",
"usage_detection_event_reference",
"attribution_subject",
"attribution_assessment",
"review_policy",
"boundary_policy",
"created_at"
],
"properties": {
"attribution_route_id": {
"type": "string",
"description": "Unique identifier for the attribution route.",
"pattern": "^[a-zA-Z0-9.*:-]+$",
"minLength": 3,
"maxLength": 180
},
"schema_version": {
"type": "string",
"description": "Schema version used by this record.",
"const": "v0.5.0-draft"
},
"route_type": {
"type": "string",
"description": "Type of route represented by this record.",
"const": "attribution_route"
},
"status": {
"type": "string",
"description": "Current lifecycle status of the attribution route.",
"enum": [
"draft",
"candidate",
"submitted_for_review",
"under_review",
"accepted_for_review",
"rejected",
"disputed",
"escalated",
"archived",
"resolved"
]
},
"source_trace_reference": {
"type": "object",
"description": "Reference to the personal trace fingerprint associated with this attribution route.",
"additionalProperties": false,
"required": [
"trace_id",
"trace_type"
],
"properties": {
"trace_id": {
"type": "string",
"description": "Identifier of the source trace fingerprint.",
"pattern": "^[a-zA-Z0-9.*:-]+$",
"minLength": 3,
"maxLength": 180
},
"trace_type": {
"type": "string",
"enum": [
"writing_pattern",
"question_structure",
"prompt_pattern",
"conceptual_framework",
"classification_method",
"reasoning_style",
"terminology_set",
"theory_structure",
"authored_document",
"public_post",
"model_output_pattern",
"mixed_trace_fingerprint"
]
},
"trace_record_reference": {
"type": "string",
"description": "Optional reference to the trace fingerprint record.",
"maxLength": 300
},
"trace_element_ids": {
"type": "array",
"description": "Optional list of trace element identifiers involved in the attribution route.",
"uniqueItems": true,
"items": {
"type": "string",
"maxLength": 180
}
}
}
},
"usage_detection_event_reference": {
"type": "object",
"description": "Reference to the usage detection event that produced or supports this attribution route.",
"additionalProperties": false,
"required": [
"event_id"
],
"properties": {
"event_id": {
"type": "string",
"description": "Identifier of the usage detection event.",
"pattern": "^[a-zA-Z0-9.*:-]+$",
"minLength": 3,
"maxLength": 180
},
"event_record_reference": {
"type": "string",
"description": "Optional reference to the usage detection event record.",
"maxLength": 300
},
"event_status": {
"type": "string",
"enum": [
"draft",
"detected",
"candidate",
"under_review",
"accepted_for_review",
"rejected",
"disputed",
"escalated",
"archived",
"resolved"
]
}
}
},
"attribution_subject": {
"type": "object",
"description": "The person, trace, work, prompt, structure, document, or agent to which attribution may be routed.",
"additionalProperties": false,
"required": [
"subject_id",
"subject_type"
],
"properties": {
"subject_id": {
"type": "string",
"description": "Identifier of the attribution subject.",
"pattern": "^[a-zA-Z0-9.*:-]+$",
"minLength": 3,
"maxLength": 180
},
"subject_type": {
"type": "string",
"enum": [
"individual",
"creator",
"researcher",
"developer",
"organization",
"collective",
"personal_trace_fingerprint",
"document",
"prompt",
"conceptual_framework",
"agent",
"other"
]
},
"display_name": {
"type": "string",
"maxLength": 200
},
"represented_by_agent": {
"type": "string",
"description": "Optional personal AI agent identifier representing this subject.",
"maxLength": 180
}
}
},
"attribution_assessment": {
"type": "object",
"description": "Reviewable assessment of the attribution relationship. This is not proof and must remain subject to review.",
"additionalProperties": false,
"required": [
"attribution_types",
"confidence_level",
"assessment_summary"
],
"properties": {
"attribution_types": {
"type": "array",
"description": "Types of attribution relationship being proposed.",
"minItems": 1,
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"source_reference",
"conceptual_attribution",
"terminology_attribution",
"prompt_pattern_attribution",
"structural_attribution",
"document_attribution",
"model_output_attribution",
"agent_to_agent_attribution",
"communication_chain_attribution",
"unknown"
]
}
},
"confidence_level": {
"type": "string",
"description": "Confidence level of the attribution assessment. Confidence is not proof.",
"enum": [
"unknown",
"low",
"medium",
"high",
"requires_human_review"
]
},
"assessment_summary": {
"type": "string",
"description": "Human-readable summary of why attribution may be appropriate.",
"minLength": 1,
"maxLength": 3000
},
"supporting_factors": {
"type": "array",
"description": "Factors supporting the attribution route. These factors must not be treated as proof by themselves.",
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"direct_reference",
"citation_reference",
"terminology_overlap",
"structure_overlap",
"prompt_pattern_overlap",
"conceptual_similarity",
"argument_structure_similarity",
"style_similarity",
"metadata_reference",
"communication_chain_reference",
"human_confirmed_context",
"other"
]
}
},
"limitations": {
"type": "string",
"description": "Known limitations, uncertainties, or reasons this route requires review.",
"maxLength": 2000
}
}
},
"attribution_action": {
"type": "object",
"description": "Optional action that may be requested or prepared through this attribution route.",
"additionalProperties": false,
"properties": {
"requested_action": {
"type": "string",
"enum": [
"none",
"citation",
"acknowledgment",
"credit",
"source_link",
"metadata_reference",
"public_attribution",
"internal_record_attribution",
"governance_review"
],
"default": "none"
},
"action_status": {
"type": "string",
"enum": [
"not_requested",
"draft",
"candidate",
"submitted_for_review",
"accepted_for_review",
"rejected",
"disputed",
"prepared_for_external_process",
"closed"
],
"default": "candidate"
},
"action_notes": {
"type": "string",
"maxLength": 2000
}
}
},
"evidence": {
"type": "object",
"description": "Reviewable evidence references supporting the attribution route.",
"additionalProperties": false,
"properties": {
"evidence_summary": {
"type": "string",
"maxLength": 3000
},
"evidence_references": {
"type": "array",
"description": "References to evidence records, comparison records, documents, or related events.",
"items": {
"type": "string",
"maxLength": 300
}
},
"comparison_reference": {
"type": "string",
"maxLength": 300
},
"private_evidence_included": {
"type": "boolean",
"description": "Whether private evidence data is included in this route. This should normally be false.",
"default": false
}
}
},
"value_graph_reference": {
"type": "object",
"description": "Optional references to value graph nodes or edges related to this attribution route.",
"additionalProperties": false,
"properties": {
"value_graph_node_id": {
"type": "string",
"maxLength": 220
},
"value_graph_edge_id": {
"type": "string",
"maxLength": 220
},
"value_event_candidate_id": {
"type": "string",
"maxLength": 220
}
}
},
"review_policy": {
"type": "object",
"description": "Review requirements for this attribution route.",
"additionalProperties": false,
"required": [
"human_review_required",
"review_required_for"
],
"properties": {
"human_review_required": {
"type": "boolean",
"const": true
},
"review_required_for": {
"type": "array",
"minItems": 1,
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"attribution_interpretation",
"ownership_interpretation",
"public_attribution",
"claim_route_creation",
"compensation_assessment",
"external_sharing",
"governance_action",
"escalation"
]
}
},
"default_review_status": {
"type": "string",
"enum": [
"unreviewed",
"under_review",
"accepted_for_review",
"rejected",
"disputed",
"escalated",
"archived",
"resolved"
],
"default": "unreviewed"
}
}
},
"boundary_policy": {
"type": "object",
"description": "Boundary rules for interpreting this attribution route.",
"additionalProperties": false,
"required": [
"not_ownership_proof",
"not_infringement_proof",
"not_compensation_proof",
"not_claim_validity_proof",
"attribution_is_not_payment",
"similarity_is_not_proof",
"requires_human_review"
],
"properties": {
"not_ownership_proof": {
"type": "boolean",
"const": true
},
"not_infringement_proof": {
"type": "boolean",
"const": true
},
"not_compensation_proof": {
"type": "boolean",
"const": true
},
"not_claim_validity_proof": {
"type": "boolean",
"const": true
},
"attribution_is_not_payment": {
"type": "boolean",
"const": true
},
"similarity_is_not_proof": {
"type": "boolean",
"const": true
},
"requires_human_review": {
"type": "boolean",
"const": true
},
"no_automatic_accusation": {
"type": "boolean",
"const": true
},
"no_automatic_enforcement": {
"type": "boolean",
"const": true
}
}
},
"privacy_policy": {
"type": "object",
"description": "Privacy constraints for this attribution route.",
"additionalProperties": false,
"properties": {
"minimal_disclosure": {
"type": "boolean",
"default": true
},
"private_trace_data_included": {
"type": "boolean",
"description": "Whether private trace data is included in the attribution route. This should normally be false.",
"default": false
},
"public_summary_allowed": {
"type": "boolean",
"default": true
},
"external_sharing_requires_review": {
"type": "boolean",
"default": true
}
}
},
"governance": {
"type": "object",
"description": "Governance state for this attribution route.",
"additionalProperties": false,
"properties": {
"governance_status": {
"type": "string",
"enum": [
"none",
"review_requested",
"under_review",
"accepted_for_review",
"rejected",
"disputed",
"escalated",
"resolved",
"archived"
],
"default": "none"
},
"reviewer_notes": {
"type": "string",
"maxLength": 3000
},
"governance_actions": {
"type": "array",
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"review_request",
"dispute_request",
"correction_request",
"attribution_review",
"claim_review",
"return_route_review",
"governance_escalation",
"archive"
]
}
}
}
},
"related_routes": {
"type": "object",
"description": "Optional references to related claim or return routes.",
"additionalProperties": false,
"properties": {
"claim_routes": {
"type": "array",
"items": {
"type": "string",
"maxLength": 220
}
},
"return_routes": {
"type": "array",
"items": {
"type": "string",
"maxLength": 220
}
},
"representative_events": {
"type": "array",
"items": {
"type": "string",
"maxLength": 220
}
}
}
},
"external_references": {
"type": "object",
"description": "Optional references to related specs, documents, repositories, or systems.",
"additionalProperties": false,
"properties": {
"royalty_os_version": {
"type": "string",
"default": "v0.5.0-draft"
},
"related_specs": {
"type": "array",
"items": {
"type": "string",
"maxLength": 256
}
},
"related_docs": {
"type": "array",
"items": {
"type": "string",
"maxLength": 256
}
},
"related_trace": {
"type": "string",
"maxLength": 220
},
"related_usage_event": {
"type": "string",
"maxLength": 220
},
"related_agent": {
"type": "string",
"maxLength": 220
}
}
},
"notes": {
"type": "string",
"description": "Optional notes about this attribution route.",
"maxLength": 3000
},
"created_at": {
"type": "string",
"description": "Creation timestamp in date-time format.",
"format": "date-time"
},
"updated_at": {
"type": "string",
"description": "Last update timestamp in date-time format.",
"format": "date-time"
}
}
}
